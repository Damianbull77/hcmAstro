---
import Layout from "../../layouts/Layout.astro";
// Importamos tu interfaz existente
import type { Habitacion } from "../../types/habitacion";

export async function getStaticPaths() {
    // 1. Llamada a tu Cloud Function (Asegúrate de que esta URL sea la correcta)
    const response = await fetch(
        "https://us-central1-hcm2-99b6c.cloudfunctions.net/getHabitaciones",
    );
    const data = await response.json();

    // Según tu código de Firebase, el JSON trae un objeto con la propiedad "habitaciones"
    const habitaciones: Habitacion[] = data.habitaciones;

    // 2. Mapeamos para crear las rutas estáticas
    return habitaciones.map((habitacion) => ({
        params: { id: habitacion.id },
        props: { habitacion },
    }));
}

// 3. Definimos las props con el tipo correcto para evitar el error "never"
const { habitacion } = Astro.props as { habitacion: Habitacion };

// Formateador de precio para que se vea profesional ($ 150.000)
const precioFormateado = new Intl.NumberFormat("es-CO", {
    style: "currency",
    currency: "COP",
    maximumFractionDigits: 0,
}).format(habitacion.precio_noche);
---

<Layout title={`Habitación ${habitacion.nombre} - Hotel Casa Modelia`}>
    <main class="max-w-7xl mx-auto px-4 py-12">
        <!-- Navegación de migas de pan / Volver -->
        <nav class="mb-8">
            <a
                href="/"
                class="text-orange-600 hover:text-orange-700 font-medium flex items-center gap-2"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                >
                    <path
                        fill-rule="evenodd"
                        d=" cooperatives9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z"
                        clip-rule="evenodd"></path>
                </svg>
                Volver al inicio
            </a>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <!-- COLUMNA IZQUIERDA: GALERÍA (7/12 columnas) -->
            <div class="lg:col-span-7 space-y-6">
                <div class="relative group">
                    <img
                        src={habitacion.imagen_principal}
                        alt={habitacion.nombre}
                        class="w-full h-[500px] object-cover rounded-2xl shadow-2xl transition-transform duration-500 group-hover:scale-[1.01]"
                    />
                    {
                        habitacion.destacada && (
                            <span class="absolute top-4 left-4 bg-orange-500 text-white px-4 py-1 rounded-full text-sm font-bold uppercase tracking-wider">
                                Favorita de los huéspedes
                            </span>
                        )
                    }
                </div>

                <!-- Galería Secundaria Dinámica -->
                <div class="grid grid-cols-3 gap-4">
                    {
                        habitacion.galeria?.cama && (
                            <div class="overflow-hidden rounded-xl border border-gray-100 shadow-sm">
                                <img
                                    src={habitacion.galeria.cama}
                                    alt="Cama"
                                    class="w-full h-32 object-cover hover:scale-110 transition duration-300"
                                />
                            </div>
                        )
                    }
                    {
                        habitacion.galeria?.bano && (
                            <div class="overflow-hidden rounded-xl border border-gray-100 shadow-sm">
                                <img
                                    src={habitacion.galeria.bano}
                                    alt="Baño"
                                    class="w-full h-32 object-cover hover:scale-110 transition duration-300"
                                />
                            </div>
                        )
                    }
                    {
                        habitacion.galeria?.closet && (
                            <div class="overflow-hidden rounded-xl border border-gray-100 shadow-sm">
                                <img
                                    src={habitacion.galeria.closet}
                                    alt="Armario"
                                    class="w-full h-32 object-cover hover:scale-110 transition duration-300"
                                />
                            </div>
                        )
                    }
                </div>
            </div>

            <!-- COLUMNA DERECHA: INFO Y RESERVA (5/12 columnas) -->
            <div class="lg:col-span-5 flex flex-col justify-start">
                <h1 class="text-5xl font-extrabold text-gray-900 mb-2">
                    {habitacion.nombre}
                </h1>
                <p class="text-3xl font-bold text-green-700 mb-6">
                    {precioFormateado}
                    <span class="text-base text-gray-500 font-normal"
                        >/ noche</span
                    >
                </p>

                <div class="prose prose-orange text-gray-700 mb-8">
                    <h3
                        class="text-lg font-bold text-gray-900 uppercase tracking-wide border-b pb-2 mb-4"
                    >
                        Sobre esta habitación
                    </h3>
                    <p class="leading-relaxed">{habitacion.descripcion}</p>
                </div>

                <!-- Especificaciones con Iconos (Simulados con texto) -->
                <div
                    class="grid grid-cols-2 gap-y-4 mb-8 bg-gray-50 p-6 rounded-2xl"
                >
                    <div class="flex flex-col">
                        <span class="text-xs uppercase text-gray-500 font-bold"
                            >Capacidad</span
                        >
                        <span class="font-semibold text-gray-800"
                            >{habitacion.capacidad} Personas</span
                        >
                    </div>
                    <div class="flex flex-col">
                        <span class="text-xs uppercase text-gray-500 font-bold"
                            >Camas</span
                        >
                        <span class="font-semibold text-gray-800"
                            >{habitacion.camas} ({habitacion.tipo_cama})</span
                        >
                    </div>
                    <div class="flex flex-col">
                        <span class="text-xs uppercase text-gray-500 font-bold"
                            >Baños</span
                        >
                        <span class="font-semibold text-gray-800"
                            >{habitacion.banos} Privado(s)</span
                        >
                    </div>
                    <div class="flex flex-col">
                        <span class="text-xs uppercase text-gray-500 font-bold"
                            >Conectividad</span
                        >
                        <span class="font-semibold text-gray-800"
                            >{
                                habitacion.wifi
                                    ? "Wi-Fi Gratis"
                                    : "No disponible"
                            }</span
                        >
                    </div>
                </div>

                <!-- Amenidades adicionales -->

                <!-- Botón de Reserva Directo -->
                <a
                    href={`https://wa.me/573000000000?text=Hola,%20me%20gustaría%20reservar%20la%20${encodeURIComponent(habitacion.nombre)}.%20¿Me%20podrían%20dar%20información%20sobre%20disponibilidad?`}
                    target="_blank"
                    class="block w-full text-center bg-green-600 hover:bg-green-700 text-white font-black py-5 rounded-2xl shadow-xl transition-all transform hover:-translate-y-1 active:scale-95 text-xl"
                >
                    ¡Reservar ahora!
                </a>
                <p class="text-center text-xs text-gray-400 mt-4 italic">
                    Reserva garantizada vía WhatsApp Business
                </p>
            </div>
        </div>
    </main>
</Layout>
